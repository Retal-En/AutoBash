<?xml version="1.0"?>
<odoo>

    <record id="auto_res_partner_view_buttons" model="ir.ui.view">
        <field name="name">res.partner.view.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="3"/>
        <!--        <field name="groups_id" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>-->
        <field name="arch" type="xml">
            <field name="company_type" position="before">
                <field name="company_type_advance" widget="radio" class="oe_edit_only" options="{'horizontal': true}"/>
            </field>
            <field name="company_type" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="vat" position="after">
<!--                <group string="Customer Information" attrs="{'invisible': [('customer','!=',True)]}" colspan="2">-->
                <group string="Customer Information">

                    <field name="gender"/>
                    <field name="age_range"/>
                    <field name="age"/>
                    <field name="id_type" widget="radio"/>
                    <field name="id_no" placeholder="e.g. BE0477472701"/>
                </group>
            </field>

        </field>
    </record>

</odoo>
