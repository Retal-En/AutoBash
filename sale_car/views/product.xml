<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="auto_product_template_inherit_1" model="ir.ui.view">
            <field name="name">product.template.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view" />
            <field name="arch" type="xml">
                <field name="default_code" position="before">
                    <field name="is_car"/>

                    <field name="model_year" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="brand_id" attrs="{'required':[('is_car','=','is_car')]}"/>
                    <field name="fuel" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="drive_train" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="insurance_price" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="registration_price" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>

                </field>
                <!--                <field name="list_price" position="after">-->
                <!--                    <field name="crf_price" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>-->

                <!--                </field>-->
            </field>
        </record>

        <record id="view_product_template_search_inherit" model="ir.ui.view">
            <field name="name">product.template.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_search_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="model_year" string="Model Year" filter_domain="[('model_year','ilike',self)]"/>
                    <field name="brand_id" string="Brand" filter_domain="[('brand','ilike',self)]"/>
                </xpath>
            </field>
        </record>

