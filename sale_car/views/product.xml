            <field name="inherit_id" ref="stock.view_stock_quant_form"/>
            <field name="arch" type="xml">
                <field name="lot_id" position="after">
                    <field name="product_state" groups="stock.group_production_lot"/>
                </field>
            </field>
        </record> -->

        <record id="inherit_view_stock_quant_tree" model="ir.ui.view">
            <field name="name">stock.quant.tree</field>
            <field name="model">stock.quant</field>
            <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
            <field name="arch" type="xml">
                <field name="lot_id" position="after">
                    <field name="product_state" groups="stock.group_production_lot"/>
                </field>
                <tree position="attributes">
                    <attribute name="decoration-muted"> product_state == 'hold'</attribute>
                    <attribute name="decoration-danger">product_state not in ['hold','normal'] </attribute>
                </tree>
            </field>
        </record>

        <record id="product_pricelist_view_inherit" model="ir.ui.view">
            <field name="name">product.pricelist.form</field>
            <field name="model">product.pricelist</field>
            <field name="inherit_id" ref="product.product_pricelist_view" />
            <field name="arch" type="xml">
                <field name="country_group_ids" position="before">
                    <field name="payment_method"/>
                </field>

            </field>
        </record>


        <record id="action_hold_production_lot_tree_view" model="ir.actions.act_window">
            <field name="name">Hold Product</field>
            <field name="res_model">stock.quant</field>
            <!-- <field name="view_type">form</field> -->
            <field name="domain"> [('product_state', '=', 'hold'),('product_id.is_car','=',True),('location_id.usage','=', 'internal')]</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="stock.view_stock_quant_tree"/>
        </record>

        <menuitem name="Hold Product" parent="sale.product_menu_catalog"  id="menu_hold_product_view"  action="action_hold_production_lot_tree_view"/>

        <record id="action_block_production_lot_tree_view" model="ir.actions.act_window">
            <field name="name">Block Product</field>
            <field name="res_model">stock.quant</field>
            <!-- <field name="view_type">form</field> -->
            <field name="domain">[('product_state','not in', ['hold','normal',False]),('product_id.is_car','=',True),('location_id.usage','=', 'internal')]</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="stock.view_stock_quant_tree"/>
        </record>

        <menuitem name="Block Product" parent="sale.product_menu_catalog"  id="menu_block_product_view"  action="action_block_production_lot_tree_view"/>



