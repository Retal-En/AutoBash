                </xpath>
            </field>
        </record> -->


        <record id="view_product_product_search_inherit" model="ir.ui.view">
            <field name="name">product.product.inherit</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_search_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="model_year" string="Model Year" filter_domain="[('model_year','ilike',self)]"/>
                    <field name="brand_id" string="Brand" filter_domain="[('brand','ilike',self)]"/>
                </xpath>
            </field>
        </record>
        <record id="auto_product_product_inherit" model="ir.ui.view">
            <field name="name">product.product.form</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view" />
            <field name="arch" type="xml">
                <field name="categ_id" position="after">
                    <field name="is_car"/>
                    <field name="model_year" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="brand_id" attrs="{'required':[('is_car','=','is_car')]}"/>
                    <field name="displacement" invisible="1"/>
                    <field name="transmission" invisible="1"/>
                    <field name="fuel" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="drive_train" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="insurance_price" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="registration_price" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="car_color" invisible="1"/>
                </field>
            </field>
        </record>

        <record id="view_car_product_template_tree" model="ir.ui.view">
            <field name="name">product.template.car.tree.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="is_car" invisible="1"/>
                    <field name="model_year" attrs="{'invisible':[('is_car', '!=', 'is_car')]}"/>
                    <field name="brand_id" attrs="{'invisible':[('is_car', '!=', 'is_car')]}"/>
                </field>
            </field>
        </record>


        <record id="view_car_product_tree" model="ir.ui.view">
            <field name="name">product.car.tree.inherit</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="is_car" invisible="1"/>
                    <field name="model_year" attrs="{'invisible':[('is_car', '!=', 'is_car')]}"/>
                    <field name="brand_id" attrs="{'invisible':[('is_car', '!=', True)]}"/>
                </field>
            </field>
        </record>


        <record model="ir.ui.view" id="product_kanban_auto_view">
            <field name="name">Product Kanban Stock</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_kanban_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <small t-if="record.model_year.value"><field name="model_year"/></small>
                </field>
                <ul position="inside">
                    <field name="type" invisible="1"/>
                    <li t-if="record.type.raw_value == 'product'">On hand: <field name="qty_available"/> <field name="uom_id"/></li>
                </ul>
            </field>
        </record>
        <record id="stock.stock_product_normal_action" model="ir.actions.act_window">
            <field name="view_mode">kanban,tree,form</field>
        </record>
        <record id="product.product_normal_action_sell" model="ir.actions.act_window">
            <field name="view_id" ref="product_kanban_auto_view"/>
        </record>

        <record id="sale_production_lot_view_form" model="ir.ui.view">
            <field name="name">stock.production.lot.form</field>
            <field name="model">stock.production.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form"/>
            <field name="arch" type="xml">
                <field name="ref" position="before">
                    <field name="lot_state" widget="radio" groups="stock.group_production_lot"/>
                    <!-- <field name="is_car"  groups="stock.group_production_lot" invisible="1"/> -->
                    <!-- <field name="engine_no"  groups="stock.group_production_lot" attrs="{'invisible':[('is_car','!=','is_car')],'required':[('is_car','=','is_car')]}"/>
                    <field name="vehicle"  groups="stock.group_production_lot" attrs="{'invisible':[('is_car','!=','is_car')]}" readonly="1"/> -->
                </field>
            </field>
        </record>

        <record id="sale_production_lot_view_tree" model="ir.ui.view">
            <field name="name">stock.production.lot.tree</field>
            <field name="model">stock.production.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_tree"/>
            <field name="arch" type="xml">
                <field name="create_date" position="before">
                    <field name="lot_state" groups="stock.group_production_lot"/>
                </field>
                <tree position="attributes">
                    <attribute name="decoration-muted"> lot_state == 'hold'</attribute>
                    <attribute name="decoration-danger">lot_state not in ['hold','normal'] </attribute>
                </tree>
            </field>
        </record>

